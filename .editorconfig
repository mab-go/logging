root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[go.mod]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = tab
tab_width = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2
